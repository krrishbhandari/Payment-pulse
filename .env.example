# Payment Pulse - Environment Variables Template
# Copy this file to .env.local and fill in your actual credentials

# ===== PAYMENT GATEWAY (Razorpay) =====
# Get your keys from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here
VITE_RAZORPAY_KEY_SECRET=your_secret_key_here

# ===== COMMUNICATION SERVICES (Twilio) =====
# Get your credentials from: https://console.twilio.com/
VITE_TWILIO_ACCOUNT_SID=your_account_sid_here
VITE_TWILIO_AUTH_TOKEN=your_auth_token_here
VITE_TWILIO_PHONE_NUMBER=+1234567890
VITE_TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ===== EMAIL SERVICE (SendGrid) =====
# Get your API key from: https://app.sendgrid.com/settings/api_keys
VITE_SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ===== SUPABASE (Already configured) =====
# These should already be in your .env file
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===== OPTIONAL: AI/ML Services =====
# For advanced features (future enhancements)
# VITE_OPENAI_API_KEY=sk-your_openai_key_here
# VITE_GEMINI_API_KEY=your_gemini_key_here